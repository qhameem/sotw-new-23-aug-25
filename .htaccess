<IfModule mod_rewrite.c>
    RewriteEngine On

    # Current production OpenLiteSpeed docRoot is the project root, so bot
    # blocking needs to exist here to affect site URLs like /alternatives/*.
    RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|SERankingBacklinksBot|Bytespider|TikTokSpider) [NC]
    RewriteRule .* - [F,L]
</IfModule>
