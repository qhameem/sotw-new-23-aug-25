LIVE_SYNC_SSH_HOST=your-server-host
LIVE_SYNC_SSH_USER=your-ssh-user
LIVE_SYNC_SSH_PORT=22

LIVE_SYNC_REMOTE_STORAGE_ROOT=/absolute/path/to/laravel-app/storage/app/public

LIVE_SYNC_REMOTE_DB_HOST=127.0.0.1
LIVE_SYNC_REMOTE_DB_PORT=3306
LIVE_SYNC_REMOTE_DB_DATABASE=your_live_database
LIVE_SYNC_REMOTE_DB_USERNAME=your_live_db_user
LIVE_SYNC_REMOTE_DB_PASSWORD=your_live_db_password

# Space-separated directories inside storage/app/public to sync.
LIVE_SYNC_MEDIA_DIRS="logos product_media theme/branding"

# Optional
LIVE_SYNC_USE_DELETE=0
